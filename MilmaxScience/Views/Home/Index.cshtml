@model IEnumerable<MilmaxScience.Models.Event>



<div class="container-fluid py-5 text-center">

    <div class="bg-light rounded-4 shadow p-5">

        <img src="~/images/ms_bg.png"
             class="img-fluid"
             style="max-width:700px; width:100%; object-fit:contain;" />

    </div>

</div>


<div class="container py-4">

    <div class="row justify-content-center mb-5">

        ```
        <div class="col-lg-10">

            <div class="bg-dark text-white rounded-4 shadow p-5 text-center">

                <h2 class="fw-bold mb-3">
                    Более 1000 научных мероприятий по всей России
                </h2>

                <p class="fs-5 mb-0">
                    От астрофизики и медицины до психологии и криминалистики —
                    мы создаём площадку, где наука становится понятной,
                    интересной и доступной каждому.
                </p>

            </div>

        </div>
        ```

    </div>


    <h3 class="mt-5">Основные направления деятельности:</h3>
    <ul class="list-group list-group-flush mb-4">
        <li class="list-group-item">Проведение научно-популярных лекций, шоу и дискуссий</li>
        <li class="list-group-item">Организация встреч с экспертами и практиками</li>
        <li class="list-group-item">Развитие образовательной среды в различных городах</li>
        <li class="list-group-item">Формирование доступного научного контента</li>
    </ul>

    <h3 class="mt-4">За время существования проекта:</h3>
    <div class="row text-center mt-3">

        <div class="col-md-4 mb-3">
            <div class="card p-3 shadow-sm">
                <h2 class="fw-bold">1000+</h2>
                <p class="mb-0">мероприятий</p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 shadow-sm">
                <h2 class="fw-bold">10+</h2>
                <p class="mb-0">городов</p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 shadow-sm">
                <h2 class="fw-bold">10000+</h2>
                <p class="mb-0">участников</p>
            </div>
        </div>

    </div>

</div>

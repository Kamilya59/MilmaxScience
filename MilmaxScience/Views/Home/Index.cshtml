@model IEnumerable<MilmaxScience.Models.Event>

<h2 class="mb-4">Ближайшие мероприятия</h2>
<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">

                <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                                   ? "https://via.placeholder.com/400x250"
                                                                   : item.ImageUrl)"
                     class="card-img-top"
                     style="height:220px; object-fit:cover;"
                     alt="Event Image">

                <div class="card-body d-flex flex-column">

                    <h5>@item.Title</h5>

                    <p class="text-muted">
                        <strong>Город:</strong> @item.City?.Name
                    </p>

                    <p class="text-muted">
                        <strong>Лектор:</strong> @item.Speaker?.FullName
                    </p>

                    <p class="text-muted">
                        <strong>Дата:</strong>
                        @item.EventDateTime.ToString("dd.MM.yyyy HH:mm")
                    </p>

                    <p>@item.ShortDescription</p>

                    <div class="mt-auto">

                        <a asp-controller="Events"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-dark w-100 mb-2">
                            Подробнее
                        </a>
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a asp-area="Identity"
                               asp-page="/Account/Login"
                               class="btn btn-dark w-100">
                                Записаться
                            </a>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin"
                               asp-action="Registrations"
                               asp-route-id="@item.Id"
                               class="btn btn-dark w-100">
                                Управление записями
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Registrations"
                               asp-action="Confirm"
                               asp-route-id="@item.Id"
                               class="btn btn-dark w-100">
                                Записаться
                            </a>
                        }
                    </div>

                </div>
            </div>
        </div>
    }
</div>
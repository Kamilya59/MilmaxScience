@model MilmaxScience.Models.Event

@{
    var source = ViewBag.Source as string;
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 p-4">

        <!-- Название -->
        <h1 class="fw-bold mb-3">@Model.Title</h1>

        <!-- Дата -->
        <h5 class="text-muted mb-3">
            📅 @Model.EventDateTime.ToString("dd.MM.yyyy HH:mm")
        </h5>

        <!-- Адрес -->
        <p class="mb-4">
            📍 <strong>@Model.Address</strong>
        </p>

        <!-- ❗ ЕСЛИ АДМИН → ВСЁ -->
        @if (isAdmin)
        {
            <hr />

            <p><strong>Краткое описание:</strong> @Model.ShortDescription</p>
            <p><strong>Полное описание:</strong> @Model.FullDescription</p>
            <p><strong>Макс. участников:</strong> @Model.MaxParticipants</p>
            <p><strong>Город:</strong> @Model.City?.Name</p>
            <p><strong>Категория:</strong> @Model.EventType?.Name</p>
            <p><strong>Организатор:</strong> @Model.Organiser?.Name</p>
        }
        else
        {
            <!-- ❗ ОБЫЧНЫЙ ПОЛЬЗОВАТЕЛЬ -->

            <div class="mb-4 p-4 bg-light rounded-3">
                <h5>Описание</h5>
                <p style="line-height:1.7;">
                    @Model.FullDescription
                </p>
            </div>

            <!-- Спикер -->
            <div class="border-top pt-4">
                <h5>Спикер</h5>
                <p class="fw-bold">@Model.Speaker?.FullName</p>
                <p class="text-muted">@Model.Speaker?.Description</p>
            </div>
        }

        <!-- КНОПКИ -->
        <div class="mt-4 d-flex gap-2">

            @if (isAdmin)
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-dark">
                    Редактировать
                </a>
            }

            <!-- 🔥 УМНЫЙ НАЗАД -->
            @if (source == "profile")
            {
                <a asp-controller="Profile"
                   asp-action="Index"
                   class="btn btn-outline-dark">
                    Назад в профиль
                </a>
            }
            else if (source == "events")
            {
                <a asp-controller="Events"
                   asp-action="Index"
                   class="btn btn-outline-dark">
                    К мероприятиям
                </a>
            }
            else
            {
                <a asp-controller="AdminEvents"
                   asp-action="Index"
                   class="btn btn-outline-dark">
                    Назад
                </a>
            }

        </div>

    </div>
</div>
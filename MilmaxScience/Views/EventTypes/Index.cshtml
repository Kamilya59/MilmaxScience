@model IEnumerable<MilmaxScience.Models.EventType>

@{
    ViewData["Title"] = "Типы мероприятий";
}

<div class="container mt-4">

    <!-- Чёрная шапка -->
    <h1 class="mb-4">Типы мероприятий</h1>

    <!-- Кнопка создания -->
    <p>
        <a asp-action="Create" class="btn btn-dark mb-3">
            Добавить тип
        </a>
    </p>

    <!-- Таблица -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Название (системное)</th>
                        <th>Отображаемое название</th>
                        <th>Slug</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.DisplayName</td>
                            <td>@item.Slug</td>
                            <td class="text-end">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-dark">
                                    Редактировать
                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    Подробнее
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Удалить
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
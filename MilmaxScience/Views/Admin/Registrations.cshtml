@model IEnumerable<MilmaxScience.Models.Registration>

<h2>Записи на мероприятие</h2>

<div class="mb-3">
    <span class="badge bg-dark fs-6">
        @ViewBag.Count / @ViewBag.Max участников
    </span>
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Пользователь</th>
            <th>Email</th>
            <th>Дата записи</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reg in Model)
        {
            <tr>
                <td>@reg.User.FullName</td>
                <td>@reg.User.Email</td>
                <td>@reg.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Events"
   asp-action="Index"
   class="btn btn-secondary mt-3">
    Назад
</a>
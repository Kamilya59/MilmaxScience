@model IEnumerable<MilmaxScience.Models.City>

@{
    ViewData["Title"] = "Города";
}

<h1 class="mb-4">Города</h1>

<p>
    <a asp-action="Create" class="btn btn-dark mb-3">
        Добавить город
    </a>
</p>

<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Название</th>
            <th>Slug</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Slug</td>
                <td class="text-end">
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-dark">
                        Редактировать
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-danger">
                        Удалить
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
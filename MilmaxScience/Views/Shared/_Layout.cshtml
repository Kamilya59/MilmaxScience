<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MilmaxScience</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MilmaxScience.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MilmaxScience</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @await Component.InvokeAsync("CitiesMenu")

                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="PublicSpeakers"
                               asp-action="Index">
                                Лекторы
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Cities"
                                   asp-action="Index">
                                    Управление городами
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
{
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Speakers" asp-action="Index">Управление лекторами</a>
                        </li>
}
                        @if (User.IsInRole("Admin"))
                            {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Events" asp-action="Index">Мероприятия</a>
                            </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="EventTypes" asp-action="Index">Категории мероприятий</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Organisers" asp-action="Index">Партнеры</a>
                                </li>
                            }
                        </ul>
                    <div class="ms-auto">
                        <partial name="_LoginPartial"/>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="flex-fill">
        <div class="container pb-4">
            @RenderBody()
        </div>
    </main>
    
    <footer class="border-top text-muted  mt-auto">
        <div class="container text-center">
            © 2026 - MilmaxScience |
            <a href="https://vk.com/milmax_production">VK</a> |
            <a href="https://t.me/milmax_production">Telegram</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
